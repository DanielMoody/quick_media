<?php

use Drupal\Core\Form\FormStateInterface;

function quick_media_form_node_form_alter(&$form, FormStateInterface $form_state, $form_id) {

  // Only show for users who can edit content
  if (!\Drupal::currentUser()->hasPermission('access content')) {
    return;
  }

  // Attach JS library HERE
  $form['#attached']['library'][] = 'quick_media/quick_media_picker';

  $form['quick_media_picker'] = [
    '#type' => 'details',
    '#title' => t('Media Token List'),
    '#open' => FALSE,
    '#weight' => 100,
  ];
  $form['quick_media_picker']['instructions'] = [
    '#markup' => '<p>Click an image to copy its token (e.g., <code>[media:7]</code>) and paste it into your content.</p>',
  ];
  $form['quick_media_picker']['picker'] = [
    '#markup' => quick_media_render_picker(),
  ];
}

use Drupal\media\Entity\Media;
use Drupal\file\Entity\File;

function quick_media_render_picker() {

  $mids = \Drupal::entityQuery('media')
                 ->accessCheck(TRUE)
                 ->sort('mid', 'DESC')
                 ->range(0, 20)
                 ->execute();

  $media_items = \Drupal\media\Entity\Media::loadMultiple($mids);

  $output = '<div style="display:flex; gap:10px; overflow-x:auto;">';

  // Load image style once (not inside loop)
  $style = \Drupal::entityTypeManager()
                  ->getStorage('image_style')
                  ->load('medium');

  foreach ($media_items as $media) {

    $source = $media->getSource();
    $field_def = $source->getSourceFieldDefinition($media->bundle->entity);

    if (!$field_def) {
      continue;
    }

    $field_name = $field_def->getName();
    $item = $media->get($field_name)->first();

    if (!$item || empty($item->target_id)) {
      continue;
    }

    $file = \Drupal\file\Entity\File::load((int) $item->target_id);
    if (!$file) {
      continue;
    }

    $uri = $file->getFileUri();

    // Use image style if available
    if ($style) {
      $url = $style->buildUrl($uri);
    }
    else {
      $url = \Drupal::service('file_url_generator')
                    ->generateAbsoluteString($uri);
    }

    $mid = $media->id();

    $token = '[media:' . $mid . ']';

    $output .= '<div class="quick-media-item" data-token="' . htmlspecialchars($token, ENT_QUOTES, 'UTF-8') . '" style="text-align:center; cursor:pointer;">';

    $output .= '<img src="' . htmlspecialchars($url, ENT_QUOTES, 'UTF-8') . '" style="height:80px; width:auto; display:block;">';
    $output .= '<small>[media:' . $mid . ']</small>';

    $output .= '</div>';
  }

  $output .= '</div>';

  return $output;
}

